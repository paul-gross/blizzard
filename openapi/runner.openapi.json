{
  "components": {
    "schemas": {
      "AskRequest": {
        "description": "A worker's ask: the question and its optional pipe-separated choices.",
        "properties": {
          "options": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Options",
            "type": "array"
          },
          "question": {
            "title": "Question",
            "type": "string"
          }
        },
        "required": [
          "question"
        ],
        "title": "AskRequest",
        "type": "object"
      },
      "AskResponse": {
        "description": "The recorded ask \u2014 its minted question id (openapi-ts consumes this).",
        "properties": {
          "lease_id": {
            "title": "Lease Id",
            "type": "string"
          },
          "question_id": {
            "title": "Question Id",
            "type": "string"
          },
          "recorded": {
            "title": "Recorded",
            "type": "boolean"
          }
        },
        "required": [
          "recorded",
          "question_id",
          "lease_id"
        ],
        "title": "AskResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HeartbeatRequest": {
        "description": "A worker's heartbeat: the lease it inherited at spawn (``BLIZZARD_LEASE_ID``).",
        "properties": {
          "lease_id": {
            "title": "Lease Id",
            "type": "string"
          }
        },
        "required": [
          "lease_id"
        ],
        "title": "HeartbeatRequest",
        "type": "object"
      },
      "HeartbeatResponse": {
        "description": "The recorded acknowledgement (openapi-ts consumes this).",
        "properties": {
          "lease_id": {
            "title": "Lease Id",
            "type": "string"
          },
          "recorded": {
            "title": "Recorded",
            "type": "boolean"
          }
        },
        "required": [
          "recorded",
          "lease_id"
        ],
        "title": "HeartbeatResponse",
        "type": "object"
      },
      "PmItemEntry": {
        "description": "One pointer's pass-through PM item (D-047/D-074) \u2014 body + comment thread, vendor-native.\n\n``label`` is the board-legible pointer label (D-075) \u2014 ``gh:blizzard#8`` \u2014 null when the\nURL is not issue-shaped. A per-pointer forge failure degrades here rather than failing the\nwhole read (D-084): ``error`` carries the reason and ``body`` is null, so one unreachable\npointer never blinds the reader to the pointers it did reach.",
        "properties": {
          "body": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Body"
          },
          "comments": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Comments",
            "type": "array"
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          },
          "fetched_at": {
            "title": "Fetched At",
            "type": "string"
          },
          "label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Label"
          },
          "provider": {
            "title": "Provider",
            "type": "string"
          },
          "url": {
            "title": "Url",
            "type": "string"
          }
        },
        "required": [
          "provider",
          "url",
          "fetched_at"
        ],
        "title": "PmItemEntry",
        "type": "object"
      },
      "PmItemsView": {
        "description": "A chunk's pass-through PM items (D-074/D-084) \u2014 one entry per pointer, order preserved.\n\nEmpty when the chunk holds no pointers \u2014 the board's empty state; a grouped chunk carrying\nmany pointers (D-047) yields one entry per pointer, each fetched fresh and never stored.",
        "properties": {
          "items": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/PmItemEntry"
            },
            "title": "Items",
            "type": "array"
          }
        },
        "title": "PmItemsView",
        "type": "object"
      },
      "ReadinessResponse": {
        "description": "The wire shape of a readiness reading (openapi-ts consumes this).",
        "properties": {
          "detail": {
            "title": "Detail",
            "type": "string"
          },
          "expected_revision": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Expected Revision"
          },
          "ready": {
            "title": "Ready",
            "type": "boolean"
          },
          "store_reachable": {
            "title": "Store Reachable",
            "type": "boolean"
          },
          "store_revision": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Store Revision"
          }
        },
        "required": [
          "ready",
          "store_reachable",
          "store_revision",
          "expected_revision",
          "detail"
        ],
        "title": "ReadinessResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "WorkspacePromptReplacement": {
        "description": "A replacement workspace prompt \u2014 applies to subsequent spawns with no restart.",
        "properties": {
          "prompt": {
            "title": "Prompt",
            "type": "string"
          }
        },
        "required": [
          "prompt"
        ],
        "title": "WorkspacePromptReplacement",
        "type": "object"
      },
      "WorkspacePromptResponse": {
        "description": "The effective workspace prompt prepended to every worker spawn (openapi-ts consumes this).",
        "properties": {
          "prompt": {
            "title": "Prompt",
            "type": "string"
          }
        },
        "required": [
          "prompt"
        ],
        "title": "WorkspacePromptResponse",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "blizzard-runner",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/chunks/{chunk_id}/pm-items": {
      "get": {
        "description": "Forward a chunk's PM-items read to the hub \u2014 the layered pass-through (D-084).",
        "operationId": "get_pm_items_api_chunks__chunk_id__pm_items_get",
        "parameters": [
          {
            "in": "path",
            "name": "chunk_id",
            "required": true,
            "schema": {
              "title": "Chunk Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PmItemsView"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Pm Items",
        "tags": [
          "runner"
        ]
      }
    },
    "/api/health": {
      "get": {
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Api Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health",
        "tags": [
          "meta"
        ]
      }
    },
    "/api/heartbeat": {
      "post": {
        "description": "Record a lease heartbeat, stamped with the injected clock (D-069).",
        "operationId": "heartbeat_api_heartbeat_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HeartbeatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HeartbeatResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Heartbeat",
        "tags": [
          "runner"
        ]
      }
    },
    "/api/leases/{lease_id}/asks": {
      "post": {
        "description": "Record a worker's ask against its lease, minting the question id ([ask-answer.md]).",
        "operationId": "record_ask_api_leases__lease_id__asks_post",
        "parameters": [
          {
            "in": "path",
            "name": "lease_id",
            "required": true,
            "schema": {
              "title": "Lease Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AskRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AskResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Record Ask",
        "tags": [
          "runner"
        ]
      }
    },
    "/api/ready": {
      "get": {
        "operationId": "ready_api_ready_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Ready",
        "tags": [
          "meta"
        ]
      }
    },
    "/api/workspace-prompt": {
      "get": {
        "description": "The effective spawn preamble prompt: the runtime override if set, else static config (issue #17).",
        "operationId": "read_workspace_prompt_api_workspace_prompt_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkspacePromptResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Read Workspace Prompt",
        "tags": [
          "runner"
        ]
      },
      "put": {
        "description": "Replace the runtime workspace-prompt override \u2014 effective on subsequent spawns (issue #17).",
        "operationId": "replace_workspace_prompt_api_workspace_prompt_put",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkspacePromptReplacement"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkspacePromptResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Replace Workspace Prompt",
        "tags": [
          "runner"
        ]
      }
    }
  }
}
