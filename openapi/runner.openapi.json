{
  "components": {
    "schemas": {
      "AskRequest": {
        "description": "A worker's ask: the question and its optional pipe-separated choices.",
        "properties": {
          "options": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Options",
            "type": "array"
          },
          "question": {
            "title": "Question",
            "type": "string"
          }
        },
        "required": [
          "question"
        ],
        "title": "AskRequest",
        "type": "object"
      },
      "AskResponse": {
        "description": "The recorded ask \u2014 its minted question id (openapi-ts consumes this).",
        "properties": {
          "lease_id": {
            "title": "Lease Id",
            "type": "string"
          },
          "question_id": {
            "title": "Question Id",
            "type": "string"
          },
          "recorded": {
            "title": "Recorded",
            "type": "boolean"
          }
        },
        "required": [
          "recorded",
          "question_id",
          "lease_id"
        ],
        "title": "AskResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HeartbeatRequest": {
        "description": "A worker's heartbeat: the lease it inherited at spawn (``BLIZZARD_LEASE_ID``).",
        "properties": {
          "lease_id": {
            "title": "Lease Id",
            "type": "string"
          }
        },
        "required": [
          "lease_id"
        ],
        "title": "HeartbeatRequest",
        "type": "object"
      },
      "HeartbeatResponse": {
        "description": "The recorded acknowledgement (openapi-ts consumes this).",
        "properties": {
          "lease_id": {
            "title": "Lease Id",
            "type": "string"
          },
          "recorded": {
            "title": "Recorded",
            "type": "boolean"
          }
        },
        "required": [
          "recorded",
          "lease_id"
        ],
        "title": "HeartbeatResponse",
        "type": "object"
      },
      "ReadinessResponse": {
        "description": "The wire shape of a readiness reading (openapi-ts consumes this).",
        "properties": {
          "detail": {
            "title": "Detail",
            "type": "string"
          },
          "expected_revision": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Expected Revision"
          },
          "ready": {
            "title": "Ready",
            "type": "boolean"
          },
          "store_reachable": {
            "title": "Store Reachable",
            "type": "boolean"
          },
          "store_revision": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Store Revision"
          }
        },
        "required": [
          "ready",
          "store_reachable",
          "store_revision",
          "expected_revision",
          "detail"
        ],
        "title": "ReadinessResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "blizzard-runner",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Api Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health",
        "tags": [
          "meta"
        ]
      }
    },
    "/api/heartbeat": {
      "post": {
        "description": "Record a lease heartbeat, stamped with the injected clock (D-069).",
        "operationId": "heartbeat_api_heartbeat_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HeartbeatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HeartbeatResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Heartbeat",
        "tags": [
          "runner"
        ]
      }
    },
    "/api/leases/{lease_id}/asks": {
      "post": {
        "description": "Record a worker's ask against its lease, minting the question id ([ask-answer.md]).",
        "operationId": "record_ask_api_leases__lease_id__asks_post",
        "parameters": [
          {
            "in": "path",
            "name": "lease_id",
            "required": true,
            "schema": {
              "title": "Lease Id",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AskRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AskResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Record Ask",
        "tags": [
          "runner"
        ]
      }
    },
    "/api/ready": {
      "get": {
        "operationId": "ready_api_ready_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Ready",
        "tags": [
          "meta"
        ]
      }
    }
  }
}
