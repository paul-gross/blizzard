  "info": {
    "title": "blizzard-hub",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/chunks": {
      "get": {
        "description": "The fleet chunk list \u2014 derived status per chunk (D-004).",
        "operationId": "list_chunks_api_chunks_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ChunkSummary"
                  },
                  "title": "Response List Chunks Api Chunks Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "List Chunks",
        "tags": [
          "chunks"
        ]
      },
      "post": {
        "description": "Ingest by pointer (D-047); 409 on a pointer held by a live chunk (D-093).",
        "operationId": "ingest_chunk_api_chunks_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChunkIngestRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChunkIngestResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
